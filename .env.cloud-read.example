# Optional cloud data inspection profile. Do not use this as your normal
# development profile, and prefer a read-only database user.
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECRET_KEY=dev-only-change-me

# Start the Cloud SQL Auth Proxy in another terminal:
#   make cloud-sql-proxy
#
# Then point Django at the proxy. Replace the user/password with a dedicated
# read-only Cloud SQL user once created.
DATABASE_URL=postgresql://podcast_readonly:REPLACE_ME@127.0.0.1:5433/podcast_network

# Leave blank unless you are actively testing extraction locally.
OPENAI_API_KEY=
