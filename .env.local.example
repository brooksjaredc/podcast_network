# Local development defaults. Copy to .env for everyday local work.
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECRET_KEY=dev-only-change-me

# Preferred local database. Create it with:
#   createdb podcast_network
DATABASE_URL=postgresql:///podcast_network

# Leave blank unless you are actively testing extraction locally.
OPENAI_API_KEY=
